{
  "partitions": 3,
  "max_concurrency": 10,
  "coverage": { "mod": "native", "limit": 0, "html": false },
  "run": ["format", "compile", "compile_test", "dialyzer", "credo", "credo_strict", "sobelow", "test"],
  "fast": ["format", "compile", "compile_test", "credo", "credo_strict", "modified_test_modules"],
  "checks": {
    "format": { "name": "Formatting", "run": "mix format --check-formatted" },
    "compile": { "name": "Compile", "run": "mix compile --warnings-as-errors" },
    "compile_test": { "name": "Compile (test)", "run": "MIX_ENV=test mix compile --warnings-as-errors" },
    "dialyzer": { "name": "Dialyzer", "run": "mix dialyzer" },
    "credo": { "name": "Credo", "run": "mix credo --all" },
    "credo_strict": { "name": "Credo Strict", "run": "mix credo --strict --all" },
    "sobelow": { "name": "Sobelow", "run": "mix sobelow --config" },
    "modified_tests": { "name": "Modified Tests", "run": "builtin:modified_tests" },
    "modified_test_modules": { "name": "Modified Test Modules", "run": "builtin:modified_test_modules" }
  }
}
